    "lint": "tsc --noEmit && eslint . --fix"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "hono": "^4.12.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@types/bun": "latest",
    "eslint": "^9.20.0"
  }
}
