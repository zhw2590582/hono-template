{
  "name": "my-app",
  "type": "module",
  "version": "1.0.0",
  "description": "Enterprise-grade Hono web application",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
