# Server
NODE_ENV=development
PORT=3000

# API
API_PREFIX=/api/v1

# Logging
LOG_LEVEL=info

# Security
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Database (optional)
# DATABASE_URL=postgres://user:pass@localhost:5432/db
